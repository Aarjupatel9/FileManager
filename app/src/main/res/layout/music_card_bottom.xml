<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/musicCardView"
    android:layout_width="match_parent"
    android:layout_height="156dp"
    android:layout_marginHorizontal="8dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/colorSurfaceContainerHigh"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp">

        <ImageView
            android:id="@+id/cardAlbumArt"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/baseline_music_note_24"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/cardTrackName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:marqueeRepeatLimit="marquee_forever"
            android:scrollHorizontally="true"
            android:singleLine="true"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintEnd_toStartOf="@+id/cardExpandButton"
            app:layout_constraintStart_toEndOf="@id/cardAlbumArt"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Track Name Goes Here" />

        <ImageButton
            android:id="@+id/cardExpandButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_fullscreen_24"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/colorOnSurfaceVariant" />

        <SeekBar
            android:id="@+id/cardProgressBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:thumbTint="?attr/colorPrimary"
            android:progressTint="?attr/colorPrimary"
            android:progressBackgroundTint="?attr/colorOutlineVariant"
            app:layout_constraintTop_toBottomOf="@id/cardTrackName"
            app:layout_constraintStart_toEndOf="@id/cardAlbumArt"
            app:layout_constraintEnd_toEndOf="@id/cardTrackName"
            android:layout_marginStart="12dp"/>

        <TextView
            android:id="@+id/cardCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintStart_toStartOf="@id/cardProgressBar"
            app:layout_constraintTop_toBottomOf="@id/cardProgressBar"
            tools:text="00:00" />

        <TextView
            android:id="@+id/cardTimeDivider"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" / "
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintStart_toEndOf="@id/cardCurrentTime"
            app:layout_constraintTop_toTopOf="@id/cardCurrentTime" />

        <TextView
            android:id="@+id/cardTotalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintStart_toEndOf="@id/cardTimeDivider"
            app:layout_constraintTop_toTopOf="@id/cardCurrentTime"
            tools:text="00:00" />

        <!-- Buttons Row at the bottom -->
        <ImageButton
            android:id="@+id/cardRepeatButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/baseline_loop_24"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardCurrentTime" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="@id/cardRepeatButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/cardPreviousButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                app:tint="?attr/colorOnSurface" />

            <ImageButton
                android:id="@+id/cardPlayPauseButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/baseline_play_circle_outline_24"
                app:tint="?attr/colorOnSurface" />

            <ImageButton
                android:id="@+id/cardNextButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_next"
                app:tint="?attr/colorOnSurface" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/cardStopButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:layout_constraintTop_toTopOf="@id/cardRepeatButton"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="?attr/colorError" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
