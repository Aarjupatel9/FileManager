<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="?attr/colorSurface">

    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Configure Targets/Reminders"
        android:textSize="18sp"
        android:textColor="?attr/colorPrimary"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daily Target:"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/editDailyTarget"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:hint="e.g. 108"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="End Target (Lifetime Goal):"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/editEndTarget"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:hint="e.g. 100000"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Missed Target Reminder Interval:"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/reminderSpinner"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/item_file_border" />

</LinearLayout>
